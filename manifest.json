{
  "manifest_version": 3,
  "name": "Balance — YouTube attention budget",
  "version": "0.1.0",
  "description": "Re-weights YouTube around your values: Enrich freely, Recharge on a budget, tax the Drift.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Balance"
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/content/content.js"],
      "css": ["src/content/surgery.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
